{
  "manifest_version": 3,
  "name": "Canvas to Obsidian Sync",
  "version": "0.1.1",
  "description": "Collect Canvas course data from your browser session and send to Obsidian.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    }
  },
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*.instructure.com/*",
    "https://*.canvaslms.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
