{
  "name": "obsidian-canvas-sync",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "description": "Bridge Canvas LMS content into Obsidian as Markdown",
  "workspaces": [
    "apps/obsidian-plugin",
    "apps/browser-extension"
  ],
  "scripts": {
    "build": "npm run build -w apps/obsidian-plugin && npm run build -w apps/browser-extension",
    "dev:plugin": "npm run dev -w apps/obsidian-plugin",
    "build:plugin": "npm run build -w apps/obsidian-plugin",
    "build:extension": "npm run build -w apps/browser-extension",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
